#!/usr/bin/env sh
set -e

arch="$(uname -m)"
unameOut="$(uname -s)"
case "${unameOut}" in
  Linux*)     platform=linux;;
  Darwin*)    platform=mac;;
  CYGWIN*)    platform=cygwin;;
  MSYS*)      platform=windows;;
  MINGW*)     platform=mingw;;
  Windows*|Window*) platform=windows;;
  *)          platform="UNKNOWN:${unameOut}"
esac

if [ "$platform" = "mac" ]; then
  echo "Detected MacOS"

  export HOMEBREW_NO_ENV_HINTS=1
  export HOMEBREW_NO_ANALYTICS=1

  if ! command -v brew > /dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

  brew install \
    age \
    aider \
    bat \
    axodotdev/tap/cargo-dist \
    cargo-make \
    cargo-watch \
    cmux \
    code2prompt \
    copilot-cli \
    ddgr \
    deskpad \
    docker \
    docker-credential-helper \
    docker-compose \
    dotter \
    efm-langserver \
    fd \
    ffmpeg \
    fish \
    fisher \
    flameshot \
    fnm \
    fzf \
    gh \
    git-credential-manager \
    git-gui \
    git-lfs \
    hyperfine \
    jj \
    jq \
    just \
    derailed/k9s/k9s \
    keycastr \
    kind \
    kluctl/tap/kluctl \
    kubectl \
    kubectx \
    lazydocker \
    llama.cpp \
    llm \
    localai \
    lnav \
    mise \
    mole \
    mosh \
    nono \
    opensuperwhisper \
    poppler \
    portaudio \
    pnpm \
    ripgrep \
    rustup \
    sccache \
    sops \
    talhelper \
    television \
    tig \
    tree \
    utm \
    uv \
    vim \
    vlc \
    wezterm \
    wget \
    max-sixty/worktrunk/wt \
    yq \
    zoxide \
    ;

  brew install dotenvx/brew/dotenvx
  brew install --cask \
    claude-code@latest \
    docker \
    freelens \
    ghostty \
    lm-studio \
    ollama-app \
    spokenly \
  ;

  if command -v rustup > /dev/null 2>&1; then
    rustup component add rust-src rust-analyzer
  fi

  if command -v wt > /dev/null 2>&1; then
    wt config shell install
  fi


  brew install --cask \
    disk-inventory-x \
    keepassxc \
    zed@preview \
  ;

  brew install siderolabs/tap/talosctl

  brew install eugene1g/safehouse/agent-safehouse

  # agent-browser requires remote debugging enabled in Chrome: chrome://inspect/#remote-debugging
  brew install agent-browser

  case "$(scutil --get ComputerName)" in
  *Work*)
    brew install \
      gettext \
      azure-data-studio \
      azure-cli \
      ;
    brew install --cask yubico-yubikey-manager
    ;;
  *)
    brew install --cask tailscale-app
    brew install hermes-agent
    ;;
  esac
elif [ "$platform" = "linux" ]; then
  echo "Linux Detected"
  if [ -f "/etc/arch-release" ]; then
    echo "ArchLinux detected"

    if [ "$EUID" -eq 0 ]; then
      read -p "Enter non-root username: " USERNAME
      if id "$USERNAME" >/dev/null 2>&1; then
        echo 'user found'
      else
        useradd -m -G wheel "$USERNAME"
        passwd "$USERNAME"
      fi
      pacman -Sy sudo --noconfirm
      sed -i '/%wheel ALL=(ALL:ALL) ALL/s/^#//' /etc/sudoers
    else
      USERNAME=$(whoami)
    fi
    if ! command -v paru > /dev/null 2>&1; then
      sudo pacman -S --needed --noconfirm base-devel git
      sudo rm -rf /tmp/paru-bin
      sudo -u "$USERNAME" git clone https://aur.archlinux.org/paru-bin.git /tmp/paru-bin
      oldpwd="$(pwd)"
      cd /tmp/paru-bin
      sudo -u "$USERNAME" makepkg -si --noconfirm
      cd "$oldpwd"
      rm -rf /tmp/paru-bin
    fi
    sudo -u "$USERNAME" paru -Sy --noconfirm \
      age \
      bspwm \
      curl \
      chromium \
      git \
      google-chrome \
      gvim \
      linux-headers \
      mosh \
      lua \
      picom \
      polybar \
      rofi \
      sxhkd \
      unzip \
      wezterm \
      xsel
    if [ "$arch" != "aarch64" ]; then
      sudo -u "$USERNAME" paru -Sy --noconfirm \
        dotter-rs-bin
    fi
    sudo -u "$USERNAME" paru -Sy --noconfirm xorg xfce4 sddm
    sudo -u "$USERNAME" systemctl enable sddm
  elif grep -Eiq 'debian|buntu|mint' /etc/*release; then
   echo "Debian based distro detected"
   sudo apt-get update
   sudo apt-get install -y \
     age \
     build-essential \
     curl \
     git \
     mosh \
     vim
  else
    echo "Unsupported Linux Distro"
    exit 1
  fi
elif [ "$platform" = "windows" ] || [ "$platform" = "cygwin" ] || [ "$platform" = "mingw" ]; then
  echo "Windows Detected"
  # Enable Windows sudo if not already enabled
  if ! sudo.exe config > /dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -Command 'Start-Process "$env:SystemRoot\System32\sudo.exe" -ArgumentList "config","--enable","normal" -Verb RunAs -Wait'
  fi

  # Enable Windows Developer Mode (required for symlinks without elevation)
  if ! reg.exe query "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\AppModelUnlock" /v AllowDevelopmentWithoutDevLicense 2>/dev/null | grep -q "0x1"; then
    sudo.exe reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\AppModelUnlock" /t REG_DWORD /f /v AllowDevelopmentWithoutDevLicense /d 1
  fi

  if ! cmd.exe /c where scoop > /dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser -Force; Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression"
  fi

  powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '
    $ErrorActionPreference = "Stop"
    $scoop = Get-Command scoop -ErrorAction SilentlyContinue
    if (-not $scoop) {
      $shim = Join-Path $env:USERPROFILE "scoop\shims\scoop.cmd"
      if (Test-Path $shim) {
        $env:PATH = (Split-Path $shim) + ";" + $env:PATH
      } else {
        throw "Scoop is not available after installation."
      }
    }
    if (-not (scoop bucket list | Select-String -Quiet "^extras$")) {
      scoop bucket add extras
    }
    $scoop_packages = @(
      "dotter",
      "7zip",
      "busybox",
      "clink",
      "copilot-cli",
      "fzf",
      "television",
      "zoxide"
    )
    foreach ($pkg in $scoop_packages) {
      scoop prefix $pkg *> $null
      if ($LASTEXITCODE -ne 0) {
        scoop install $pkg
      }
    }
  '
fi

if ! command -v pi > /dev/null 2>&1; then
  echo "Installing pi"
  if [ "$platform" = "mac" ] || [ "$platform" = "linux" ]; then
    curl -fsSL https://pi.dev/install.sh | sh
  elif [ "$platform" = "windows" ] || [ "$platform" = "cygwin" ] || [ "$platform" = "msys" ]; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "irm https://pi.dev/install.ps1 | iex"
  fi
fi

if command -v bun > /dev/null 2>&1; then
  bun x skills add Cocoon-AI/architecture-diagram-generator --global --yes
  bun x skills add JimLiu/baoyu-skills/skills/baoyu-image-gen --global --yes
  bun x skills add JimLiu/baoyu-skills/skills/baoyu-infographic --global --yes
  bun x skills add mattpocock/skills/skills/productivity/grill-me --global --yes
  bun x skills add https://github.com/browser-use/browser-harness-js --skill cdp --global --yes
  mkdir -p "$HOME/.local/bin"
  ln -sf "$HOME/.agents/skills/cdp/sdk/browser-harness-js" \
    "$HOME/.local/bin/browser-harness-js"
fi

# Minimum release age: only install package versions older than 7 days
# (mitigates supply-chain attacks via freshly-published malicious versions)
if command -v npm > /dev/null 2>&1; then
  if ! npm config set min-release-age=7; then
    if npm install -g npm@latest; then
      npm config set min-release-age=7 || echo "Skipping npm min-release-age; unsupported by current npm."
    else
      echo "Skipping npm min-release-age; npm update failed."
    fi
  fi
fi
if command -v pnpm > /dev/null 2>&1; then
  pnpm config set minimumReleaseAge 10080
fi
if command -v yarn > /dev/null 2>&1; then
  yarn config set -H npmMinimalAgeGate "168h"
fi
if command -v bun > /dev/null 2>&1; then
  if ! grep -q "minimumReleaseAge" "$HOME/.bunfig.toml" 2>/dev/null; then
    printf '\n[install]\nminimumReleaseAge = 604800\n' >> "$HOME/.bunfig.toml"
  fi
fi

dotfiles_dir="$HOME/.dotfiles"

if command -v git > /dev/null 2>&1; then
  if [ ! -d "$dotfiles_dir/.git" ]; then
    echo "Cloning dotfiles into $dotfiles_dir"
    git clone --recurse-submodules https://github.com/prabirshrestha/dotfiles.git "$dotfiles_dir"
  else
    echo "Skipping dotfiles clone; $dotfiles_dir already exists."
  fi
else
  echo "Skipping dotfiles clone; git is not installed."
fi

if [ -x "$dotfiles_dir/configure" ]; then
  echo "Applying dotfiles from $dotfiles_dir"
  oldpwd="$(pwd)"
  cd "$dotfiles_dir"
  ./configure
  cd "$oldpwd"
else
  echo "Skipping dotfiles apply; $dotfiles_dir/configure was not found or is not executable."
fi

if [ "$platform" = "windows" ] || [ "$platform" = "cygwin" ] || [ "$platform" = "mingw" ]; then
  if command -v clink > /dev/null 2>&1 && [ -d "$dotfiles_dir/clink" ]; then
    clink_profile="${LOCALAPPDATA:-$HOME/AppData/Local}/clink"
    echo "Configuring Clink profile in $clink_profile"
    mkdir -p "$clink_profile"
    cp "$dotfiles_dir"/clink/*.lua "$clink_profile"/
    cp "$dotfiles_dir"/clink/clink_settings "$clink_profile"/
    clink autorun install -- --profile "$clink_profile"
  fi
fi
